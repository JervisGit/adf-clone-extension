{
  "_comment": "Config-driven Copy Activity source/sink field definitions. Field keys prefixed with 'src_' (source) or 'snk_' (sink) to avoid naming collisions when both sides are flattened onto the same activity object. jsonPath is relative to the source or sink object. Fields without a jsonPath are UI-only controls (e.g. filePathType, useQuery) used to drive conditional display.",
  "datasetTypes": {
    "AzureSqlTable": {
      "name": "Azure SQL Database",
      "hasStoreSettings": false,
      "sourceTypeName": "AzureSqlSource",
      "sinkTypeName": "AzureSqlSink",
      "fields": {
        "source": {
          "src_useQuery": {
            "type": "radio",
            "label": "Use query",
            "options": ["Table", "Query", "Stored procedure"],
            "optionValues": ["Table", "Query", "Stored procedure"],
            "default": "Table"
          },
          "src_sqlReaderQuery": {
            "type": "textarea",
            "label": "Query",
            "required": true,
            "placeholder": "SELECT * FROM [schema].[table]",
            "conditional": { "field": "src_useQuery", "value": "Query" },
            "jsonPath": "sqlReaderQuery"
          },
          "src_sqlReaderStoredProcedureName": {
            "type": "text",
            "label": "Stored procedure name",
            "required": true,
            "placeholder": "sp_name",
            "conditional": { "field": "src_useQuery", "value": "Stored procedure" },
            "jsonPath": "sqlReaderStoredProcedureName"
          },
          "src_queryTimeout": {
            "type": "number",
            "label": "Query timeout (minutes)",
            "default": 120,
            "min": 1,
            "placeholder": "120",
            "jsonPath": "queryTimeout"
          },
          "src_isolationLevel": {
            "type": "select",
            "label": "Isolation level",
            "options": ["Read committed", "Read uncommitted", "Repeatable read", "Serializable", "Snapshot"],
            "optionValues": ["ReadCommitted", "ReadUncommitted", "RepeatableRead", "Serializable", "Snapshot"],
            "placeholder": "Select...",
            "jsonPath": "isolationLevel"
          },
          "src_partitionOption": {
            "type": "radio",
            "label": "Partition option",
            "options": ["None", "Physical partitions of table", "Dynamic range"],
            "optionValues": ["None", "PhysicalPartitionsOfTable", "DynamicRange"],
            "default": "None",
            "conditional": { "field": "src_useQuery", "value": "Table" },
            "jsonPath": "partitionOption"
          },
          "src_partitionColumnName": {
            "type": "text",
            "label": "Partition column name",
            "placeholder": "Column name",
            "conditional": { "field": "src_partitionOption", "value": "DynamicRange" },
            "nestedConditional": { "field": "src_useQuery", "value": "Table" },
            "jsonPath": "partitionSettings.partitionColumnName"
          },
          "src_partitionUpperBound": {
            "type": "text",
            "label": "Partition upper bound",
            "placeholder": "Upper bound value",
            "conditional": { "field": "src_partitionOption", "value": "DynamicRange" },
            "nestedConditional": { "field": "src_useQuery", "value": "Table" },
            "jsonPath": "partitionSettings.partitionUpperBound"
          },
          "src_partitionLowerBound": {
            "type": "text",
            "label": "Partition lower bound",
            "placeholder": "Lower bound value",
            "conditional": { "field": "src_partitionOption", "value": "DynamicRange" },
            "nestedConditional": { "field": "src_useQuery", "value": "Table" },
            "jsonPath": "partitionSettings.partitionLowerBound"
          },
          "src_maxConcurrentConnections": {
            "type": "number",
            "label": "Max concurrent connections",
            "min": 1,
            "jsonPath": "maxConcurrentConnections"
          }
        },
        "sink": {
          "snk_writeBehavior": {
            "type": "radio",
            "label": "Write behavior",
            "options": ["insert", "upsert", "storedProcedure"],
            "default": "insert",
            "jsonPath": "writeBehavior"
          },
          "snk_tableOption": {
            "type": "radio",
            "label": "Table option",
            "options": ["useExisting", "autoCreate"],
            "default": "useExisting",
            "jsonPath": "tableOption"
          },
          "snk_sqlWriterUseTableLock": {
            "type": "boolean",
            "label": "Bulk insert table lock",
            "default": false,
            "jsonPath": "sqlWriterUseTableLock"
          },
          "snk_preCopyScript": {
            "type": "textarea",
            "label": "Pre-copy script",
            "placeholder": "TRUNCATE TABLE [schema].[table]",
            "jsonPath": "preCopyScript"
          },
          "snk_writeBatchSize": {
            "type": "number",
            "label": "Write batch size",
            "default": 10000,
            "min": 1,
            "jsonPath": "writeBatchSize"
          },
          "snk_writeBatchTimeout": {
            "type": "text",
            "label": "Write batch timeout",
            "default": "00:30:00",
            "placeholder": "00:30:00",
            "jsonPath": "writeBatchTimeout"
          },
          "snk_maxConcurrentConnections": {
            "type": "number",
            "label": "Max concurrent connections",
            "min": 1,
            "jsonPath": "maxConcurrentConnections"
          },
          "snk_disableMetricsCollection": {
            "type": "boolean",
            "label": "Disable performance metrics analytics",
            "default": false,
            "jsonPath": "disableMetricsCollection"
          }
        }
      }
    },

