{
  "_comment": "Config-driven Copy Activity source/sink field definitions. Field keys prefixed with 'src_' (source) or 'snk_' (sink) to avoid naming collisions when both sides are flattened onto the same activity object. jsonPath is relative to the source or sink object.",
  "datasetTypes": {
    "AzureSqlTable": {
      "name": "Azure SQL Database",
      "hasStoreSettings": false,
      "sourceTypeName": "AzureSqlSource",
      "sinkTypeName": "AzureSqlSink",
      "fields": {
        "source": {
          "src_sqlReaderQuery": {
            "type": "textarea",
            "label": "Query",
            "placeholder": "SELECT * FROM [schema].[table]",
            "jsonPath": "sqlReaderQuery"
          },
          "src_isolationLevel": {
            "type": "select",
            "label": "Isolation level",
            "options": ["None", "ReadCommitted", "ReadUncommitted", "RepeatableRead", "Serializable", "Snapshot"],
            "jsonPath": "isolationLevel"
          },
          "src_partitionOption": {
            "type": "select",
            "label": "Partition option",
            "options": ["None", "PhysicalPartitionsOfTable", "DynamicRange"],
            "default": "None",
            "jsonPath": "partitionOption"
          },
          "src_maxConcurrentConnections": {
            "type": "number",
            "label": "Max concurrent connections",
            "min": 1,
            "jsonPath": "maxConcurrentConnections"
          }
        },
        "sink": {
          "snk_writeBehavior": {
            "type": "radio",
            "label": "Write behavior",
            "options": ["insert", "upsert", "storedProcedure"],
            "default": "insert",
            "jsonPath": "writeBehavior"
          },
          "snk_tableOption": {
            "type": "radio",
            "label": "Table option",
            "options": ["useExisting", "autoCreate"],
            "default": "useExisting",
            "jsonPath": "tableOption"
          },
          "snk_sqlWriterUseTableLock": {
            "type": "boolean",
            "label": "Bulk insert table lock",
            "default": false,
            "jsonPath": "sqlWriterUseTableLock"
          },
          "snk_preCopyScript": {
            "type": "textarea",
            "label": "Pre-copy script",
            "placeholder": "TRUNCATE TABLE [schema].[table]",
            "jsonPath": "preCopyScript"
          },
          "snk_writeBatchSize": {
            "type": "number",
            "label": "Write batch size",
            "default": 10000,
            "min": 1,
            "jsonPath": "writeBatchSize"
          },
          "snk_writeBatchTimeout": {
            "type": "text",
            "label": "Write batch timeout",
            "default": "00:30:00",
            "placeholder": "00:30:00",
            "jsonPath": "writeBatchTimeout"
          },
          "snk_maxConcurrentConnections": {
            "type": "number",
            "label": "Max concurrent connections",
            "min": 1,
            "jsonPath": "maxConcurrentConnections"
          },
          "snk_disableMetricsCollection": {
            "type": "boolean",
            "label": "Disable performance metrics analytics",
            "default": false,
            "jsonPath": "disableMetricsCollection"
          }
        }
      }
    },

